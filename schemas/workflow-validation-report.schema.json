{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "workflow-validation-report.schema.json",
  "title": "Workflow Validation Report Artifact",
  "description": "Educational schema for preserving workflow validation evidence before downstream agent execution.",
  "type": "object",
  "required": [
    "artifact_type",
    "version",
    "workflows_reviewed",
    "warnings",
    "blocking_findings",
    "safe_next_action"
  ],
  "properties": {
    "artifact_type": {
      "const": "workflow_validation_report"
    },
    "version": {
      "type": "string"
    },
    "workflows_reviewed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "purpose"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": true
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocking_findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safe_next_action": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
